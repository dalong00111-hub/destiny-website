# 支付配置
PAYMENT_ENABLED=false

# 微信支付配置（沙箱）
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_MCH_ID=1230000109
WECHAT_API_KEY=abcdef1234567890abcdef1234567890
WECHAT_CERT_PATH=cert/apiclient_cert.pem
WECHAT_KEY_PATH=cert/apiclient_key.pem

# 支付宝配置（沙箱）
ALIPAY_APP_ID=2016092700601234
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ALIPAY_SIGN_TYPE=RSA2

# 回调URL（部署后更新）
NOTIFY_URL=https://your-backend-url.com/api/payment/notify
RETURN_URL=https://your-frontend-url.com/payment/result

# 运行模式
SANDBOX_MODE=true
DEBUG_MODE=true

# 数据库配置
DATABASE_URL=sqlite:///data/destiny.db

# 服务器配置
HOST=0.0.0.0
PORT=5000
SECRET_KEY=your-secret-key-here